{
  "name": "spell-forge",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:phonics": "vitest run tests/unit/phonics-engine.test.ts",
    "test:spaced-rep": "vitest run tests/unit/spaced-rep.test.ts tests/unit/difficulty-score.test.ts",
    "test:data": "vitest run tests/unit/data-layer.test.ts",
    "test:audio": "vitest run tests/unit/audio.test.ts",
    "test:ocr": "vitest run tests/unit/ocr.test.ts",
    "test:ocr-integration": "vitest run tests/unit/ocr-image.test.ts",
    "test:themes": "vitest run tests/unit/themes.test.ts",
    "test:a11y": "vitest run tests/unit/accessibility.test.ts",
    "test:adaptive": "vitest run tests/unit/adaptive-engine.test.ts",
    "test:contracts": "vitest run tests/unit/contracts.test.ts",
    "test:learning": "vitest run tests/unit/learning-engine.test.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
